# Desert to Cape — 환경변수 템플릿
# 실제 사용 시 .env 파일로 복사 후 값 입력
# GitHub Actions에서는 Secrets으로 관리 (이 파일 커밋 금지)

# Anthropic API (번역 + AI 코멘터리)
ANTHROPIC_API_KEY=sk-ant-여기에_실제_키_입력

# 스티비 API
STIBEE_API_KEY=여기에_스티비_API_키_입력
STIBEE_LIST_ID_FREE=12345          # 스티비 무료 구독자 주소록 ID
STIBEE_LIST_ID_PRO=12346           # 스티비 유료 구독자 주소록 ID (나중에)
DTC_FROM_EMAIL=newsletter@yourdomain.com
